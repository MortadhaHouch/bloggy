# Server files & folders
server/.vscode/
server/.idea/
server/*.iml
server/node_modules
server/*.env

# Client files & folders
# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/
*.iml
.env
