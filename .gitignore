# is commented out by default.
#.vscode/

# Flutter
client/build/
client/android/local.properties
client/android/gradle.properties
client/android/.gradle/
client/ios/Pods/
client/ios/Podfile.lock
client/ios/Flutter/Flutter-Release.xcconfig
client/web/plugins_debug.js
client/web/plugins_release.js
